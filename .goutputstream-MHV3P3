# Server
NODE_ENV=development
PORT=4000

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=hotelapp
PGPASSWORD=hotelapp
PGDATABASE=hotel

# JWT
JWT_SECRET=change_me_super_secret
JWT_ACCESS_TTL_SECONDS=43200

# Security
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
LOGIN_FAILS_BEFORE_LOCK=12
LOGIN_LOCK_MS=1800000

# Migrations
DB_AUTO_MIGRATE=true

# Bootstrap admin (создается, если нет ни одной учетной записи)
BOOTSTRAP_ADMIN_EMAIL=admin@hotel.local
BOOTSTRAP_ADMIN_PASSWORD=Admin12345!

